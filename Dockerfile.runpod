# Single-container RunPod image
# Bundles: vLLM (GPU inference) + Fastify proxy (caching/signing/webhooks) + nginx (auth/rate-limiting)
#
# Build (from project root, requires Docker BuildKit):
#   docker build --platform linux/amd64 -f Dockerfile.runpod -t youruser/vllm-proxy:latest .
#
# Push:
#   docker push youruser/vllm-proxy:latest

FROM vllm/vllm-openai:latest

# ── System deps: nginx, Node.js 20, supervisord, htpasswd ────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        nginx \
        supervisor \
        apache2-utils \
        curl \
        openssl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# ── Fastify proxy ─────────────────────────────────────────────────────────────
WORKDIR /app
COPY fastify-proxy/package*.json ./
RUN npm install --production
COPY fastify-proxy/src ./src

# ── nginx config (HTTP-only, port 8080) ───────────────────────────────────────
COPY nginx/nginx.conf /etc/nginx/nginx.conf
COPY nginx/conf.d/default.runpod.conf /etc/nginx/conf.d/default.conf
RUN rm -f /etc/nginx/sites-enabled/default

# ── Runtime scripts ───────────────────────────────────────────────────────────
COPY scripts/runpod/supervisord.conf /etc/supervisor/conf.d/app.conf
COPY scripts/runpod/start.sh /start.sh
COPY scripts/runpod/start-fastify.sh /app/start-fastify.sh
RUN chmod +x /start.sh /app/start-fastify.sh

EXPOSE 8080

ENTRYPOINT ["/start.sh"]
