## RunPod image tag (used by make build-runpod / push-runpod)
RUNPOD_IMAGE=youruser/vllm-proxy:latest

## vLLM / LLM backend configuration
# Model identifier (must be available in the LLM backend)
VLLM_MODEL=google/gemma-3-12b

# Where the LLM backend server listens
VLLM_HOST=localhost
VLLM_PORT=8000

# Enable/disable writing requests/responses to the encrypted SQLite cache ("false" to turn off caching)
VLLM_PROXY_SQLITE_CACHE=true
# Directory on the host where the Fastify proxy SQLite cache DB will be stored
VLLM_PROXY_SQLITE_HOST_DIR=./fastify-proxy/data

# Optional encryption key for the SQLite cache (auto-generated if empty during setup)
VLLM_SQLITE_ENCRYPTION_KEY=
# Optional secret used to HMAC-sign proxy responses (auto-generated if empty during setup)
VLLM_PROXY_RESPONSE_SIGNING_SECRET=

# Optional webhooks fired by the Fastify proxy after chat completions
VLLM_PROXY_WEBHOOK_ON_CHAT_COMPLETE=https://example.com/webhook
VLLM_PROXY_WEBHOOK_ON_CHAT_COMPLETE_HEADERS='{"Authorization":"Bearer abc123"}'

# Optional proxy timeouts (milliseconds)
# Request timeout for vLLM calls (default 900000 = 15 minutes)
VLLM_PROXY_REQUEST_TIMEOUT=900000
# Timeout for webhook calls (default 30000 = 30 seconds)
VLLM_PROXY_WEBHOOK_TIMEOUT=30000

# Optional secret used to HMAC-verify inbound requests (x-request-signature)
VLLM_PROXY_REQUEST_SIGNING_SECRET="your-shared-secret-here"

## Nginx configuration
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# Nginx timeout configuration (aligned with Fastify proxy timeout)
NGINX_KEEPALIVE_TIMEOUT=900
NGINX_PROXY_CONNECT_TIMEOUT=120
NGINX_PROXY_SEND_TIMEOUT=900
NGINX_PROXY_READ_TIMEOUT=900
NGINX_CLIENT_MAX_BODY_SIZE=10M
NGINX_PROXY_RATE_LIMIT=5r/s
NGINX_PROXY_RATE_BURST=20

## Authentication
NGINX_BASIC_AUTH_USERNAME=admin
# Leave empty or use default to auto-generate strong password during setup
NGINX_BASIC_AUTH_PASSWORD=

## Rate limiting
RATE_LIMIT=10r/s
RATE_BURST=20

## VLLM bridge (optional)
# Enable the optional VLLM bridge profile in docker-compose
VLLM_BRIDGE_ENABLED=true
VLLM_BRIDGE_PORT=8000

# VLLM bridge timeouts (seconds)
VLLM_BRIDGE_CHAT_TIMEOUT=300
VLLM_BRIDGE_MODELS_TIMEOUT=30
